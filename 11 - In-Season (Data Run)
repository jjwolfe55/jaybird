INSERT INTO lookup_run_environment  (
team_id,
season_id,
runs_for,
runs_against,
run_adj
)
WITH calc AS (
SELECT a.season_id AS season_id,
COUNT(DISTINCT(a.team_id)) AS team_count,
(b.runs_for + c.runs_against)/(COUNT(DISTINCT(a.team_id))) AS team_runs_avg
FROM standard_standings AS a
INNER JOIN (SELECT season_id, SUM(b_r) AS runs_for FROM standard_batting GROUP BY season_id) AS b
ON a.season_id = b.season_id
INNER JOIN (SELECT season_id, SUM(p_r) AS runs_against FROM standard_pitching GROUP BY season_id) AS c
ON a.season_id = c.season_id
WHERE a.season_id = 2026
GROUP BY a.season_id
ORDER BY a.season_id DESC
)
, lookup_run_environment AS (
SELECT a.team_id AS team_id,
a.season_id AS season_id,
b.runs_for AS runs_for,
c.runs_against AS runs_against,
2-((b.runs_for + c.runs_against)/d.team_runs_avg) AS run_adj
FROM standard_standings AS a
INNER JOIN (SELECT season_id, team_id, SUM(b_r) AS runs_for FROM standard_batting GROUP BY season_id,team_id) AS b
ON a.team_id = b.team_id AND a.season_id = b.season_id
INNER JOIN (SELECT season_id, team_id, SUM(p_r) AS runs_against FROM standard_pitching GROUP BY season_id,team_id) AS c
ON a.team_id = c.team_id AND a.season_id = c.season_id
INNER JOIN calc AS d
ON a.season_id = d.season_id
GROUP BY a.team_id,a.season_id
ORDER BY a.season_id DESC
)
SELECT *
FROM lookup_run_environment;

INSERT INTO rate_batting (
player_id,
player_name,
team_id,
season_id,
age,
bat,
b_avg,
b_obp,
b_slg,
b_ops,
b_iso,
b_bb_pct,
b_so_pct
)
SELECT 
a.player_id,
a.player_name,
a.team_id,
a.season_id,
a.age,
a.bat,
(CASE WHEN a.b_ab = 0 THEN NULL ELSE COALESCE((a.b_h)/(NULLIF(a.b_ab,0)),0) END),
((a.b_h+a.b_bb+a.b_hbp)/((a.b_ab+a.b_bb+a.b_hbp+a.b_sf))),
((a.b_s+a.b_d+a.b_d+a.b_t+a.b_t+a.b_t+a.b_hr+a.b_hr+a.b_hr+a.b_hr)/a.b_ab),
(((a.b_h+a.b_bb+a.b_hbp)/(a.b_ab+a.b_bb+a.b_hbp+a.b_sf)) + ((a.b_s+a.b_d+a.b_d+a.b_t+a.b_t+a.b_t+a.b_hr+a.b_hr+a.b_hr+a.b_hr)/a.b_ab)),
(((a.b_s+a.b_d+a.b_d+a.b_t+a.b_t+a.b_t+a.b_hr+a.b_hr+a.b_hr+a.b_hr)/a.b_ab) - ((a.b_h)/a.b_ab)),
((b_bb+b_ibb)/b_pa),
(b_so/b_pa)
FROM standard_batting AS a
WHERE a.season_id = 2026;

INSERT INTO rate_pitching (
player_id,
player_name,
team_id,
season_id,
age,
throw,
p_avg,
p_obp,
p_slg,
p_ops,
p_era,
p_bb_pct,
p_so_pct
)
SELECT 
    a.player_id,
    a.player_name,
    a.team_id,
    a.season_id,
    a.age,
    a.throw,
    COALESCE(a.p_h,0) /
    NULLIF(
        COALESCE(a.p_bf,0)
      - COALESCE(a.p_sf,0)
      - COALESCE(a.p_sh,0)
      - COALESCE(a.p_bb,0)
      - COALESCE(a.p_hbp,0)
      - COALESCE(a.p_ibb,0),
    0) AS p_avg,
    (
        COALESCE(a.p_h,0)
      + COALESCE(a.p_bb,0)
      + COALESCE(a.p_hbp,0)
    ) /
    NULLIF(
        (
            COALESCE(a.p_bf,0)
          - COALESCE(a.p_sf,0)
          - COALESCE(a.p_sh,0)
          - COALESCE(a.p_bb,0)
          - COALESCE(a.p_hbp,0)
          - COALESCE(a.p_ibb,0)
        )
      + COALESCE(a.p_bb,0)
      + COALESCE(a.p_hbp,0)
      + COALESCE(a.p_sf,0),
    0) AS p_obp,
    (
        COALESCE(a.p_s,0)
      + 2*COALESCE(a.p_d,0)
      + 3*COALESCE(a.p_t,0)
      + 4*COALESCE(a.p_hr,0)
    ) /
    NULLIF(
        COALESCE(a.p_bf,0)
      - COALESCE(a.p_sf,0)
      - COALESCE(a.p_sh,0)
      - COALESCE(a.p_bb,0)
      - COALESCE(a.p_hbp,0)
      - COALESCE(a.p_ibb,0),
    0) AS p_slg,
    (
        (
            COALESCE(a.p_h,0)
          + COALESCE(a.p_bb,0)
          + COALESCE(a.p_hbp,0)
        ) /
        NULLIF(
            (
                COALESCE(a.p_bf,0)
              - COALESCE(a.p_sf,0)
              - COALESCE(a.p_sh,0)
              - COALESCE(a.p_bb,0)
              - COALESCE(a.p_hbp,0)
              - COALESCE(a.p_ibb,0)
            )
          + COALESCE(a.p_bb,0)
          + COALESCE(a.p_hbp,0)
          + COALESCE(a.p_sf,0),
        0)
    )
    +
    (
        COALESCE(a.p_s,0)
      + 2*COALESCE(a.p_d,0)
      + 3*COALESCE(a.p_t,0)
      + 4*COALESCE(a.p_hr,0)
    ) /
    NULLIF(
        COALESCE(a.p_bf,0)
      - COALESCE(a.p_sf,0)
      - COALESCE(a.p_sh,0)
      - COALESCE(a.p_bb,0)
      - COALESCE(a.p_hbp,0)
      - COALESCE(a.p_ibb,0),
    0) AS p_ops,
    (COALESCE(a.p_er,0) * 9) / NULLIF(a.p_ip,0) AS p_era,
    (COALESCE(a.p_bb,0) + COALESCE(a.p_ibb,0)) / NULLIF(a.p_bf,0) AS p_bb_pct,
    COALESCE(a.p_so,0) / NULLIF(a.p_bf,0) AS p_so_pct
FROM standard_pitching AS a
WHERE a.season_id = 2026;

