UPDATE fangraphs_lines_pitching_v1
SET fan_p_ip = FLOOR(fan_p_ip) + 0.7
WHERE ROUND(fan_p_ip - FLOOR(fan_p_ip), 1) = 0.2;

UPDATE fangraphs_lines_pitching_v1
SET fan_p_ip = FLOOR(fan_p_ip) + 0.3
WHERE ROUND(fan_p_ip - FLOOR(fan_p_ip), 1) = 0.1;

